# Twitter/X handle (without @). Used by scripts/auth_login.py to name the
# session file as <session-dir>/<handle>_twitter_state.json.
TWITTER_USERNAME=

# Optional: explicit path to the Playwright storage_state JSON. If unset, the
# MCP server probes (in order):
#   1. ~/.config/twitter-mcp/sessions/<TWITTER_USERNAME>_twitter_state.json
#   2. ./sessions/<TWITTER_USERNAME>_twitter_state.json (legacy in-repo path)
#   3. the only *_twitter_state.json file it can find in either directory.
# TWITTER_SESSION_FILE=~/.config/twitter-mcp/sessions/yourhandle_twitter_state.json

# Optional: where ``download_media`` writes fetched media. Defaults to
# ./downloads (treated as temporary scratch, gitignored).
# TWITTER_DOWNLOADS_DIR=./downloads

# Optional: how long the headless Chromium can sit idle (in seconds) before
# the MCP server tears it down to free RAM. Re-launches on next tool call.
# Default 300.
# BROWSER_IDLE_TIMEOUT_S=300

# Optional: set to "false" to launch Chromium headed (useful for debugging
# the GraphQL response handlers). Defaults to true (headless).
# BROWSER_HEADLESS=true
