# Twitter/X handle (without @). Used by scripts/auth_login.py to name the
# session file as sessions/<handle>_twitter_state.json.
TWITTER_USERNAME=

# Optional: explicit path to the Playwright storage_state JSON. If unset, the
# MCP server falls back to sessions/<TWITTER_USERNAME>_twitter_state.json
# (or the only *_twitter_state.json file in sessions/).
# TWITTER_SESSION_FILE=sessions/yourhandle_twitter_state.json

# Optional: how long the headless Chromium can sit idle (in seconds) before
# the MCP server tears it down to free RAM. Re-launches on next tool call.
# Default 300.
# BROWSER_IDLE_TIMEOUT_S=300

# Optional: set to "false" to launch Chromium headed (useful for debugging
# the GraphQL response handlers). Defaults to true (headless).
# BROWSER_HEADLESS=true
